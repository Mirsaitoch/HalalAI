# Required — OpenRouter API key (https://openrouter.ai/keys)
# Used for both RAG service and backend AI features
REMOTE_LLM_API_KEY=sk-or-v1-...

# Database Configuration
DB_USERNAME=halalai
DB_PASSWORD=halalai
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long-for-hs256-change-in-production

# PostgreSQL migration (local)
LOCAL_DB_USER=mirsaitsabirzanov
LOCAL_DB_NAME=halalai

# RAG Service Configuration
OPEN_ROUTER_KEY=sk-or-v1-...  # Same as REMOTE_LLM_API_KEY
RAG_LOG_LEVEL=INFO
LLM_MODEL=openrouter/auto
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

RAG_ENABLED=true
